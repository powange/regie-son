{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Régie Son",
  "version": "0.1.0",
  "identifier": "com.pcomble.regie-son",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Régie Son",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data: blob:; media-src 'self' asset: http://asset.localhost blob:; connect-src 'self' ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM3NjNBQzA3OERFQjY4QzUKUldURmFPdU5CNnhqeHpzb0VVVWN2dGZ5azk0OWNrN3Q4RWhvd2FoZk1VM0lWWVFCSWFhTXhDd3gK",
      "endpoints": [
        "https://github.com/powange/regie-son/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/yt-dlp"],
    "linux": {
      "deb": {
        "depends": ["gstreamer1.0-libav", "gstreamer1.0-plugins-good", "gstreamer1.0-plugins-bad", "gstreamer1.0-plugins-ugly"]
      },
      "rpm": {
        "depends": ["gstreamer1-libav", "gstreamer1-plugins-good", "gstreamer1-plugins-bad-free", "gstreamer1-plugins-ugly-free"]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["regieson"],
        "name": "Projet Régie Son",
        "description": "Archive de projet Régie Son",
        "mimeType": "application/x-regieson",
        "role": "Editor"
      },
      {
        "ext": ["regiesonnumero"],
        "name": "Numéro Régie Son",
        "description": "Archive de numéro Régie Son",
        "mimeType": "application/x-regiesonnumero",
        "role": "Editor"
      }
    ]
  }
}
