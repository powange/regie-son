{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Régie Son",
  "version": "0.1.0",
  "identifier": "com.pcomble.regie-son",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Régie Son",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM3NjNBQzA3OERFQjY4QzUKUldURmFPdU5CNnhqeHpzb0VVVWN2dGZ5azk0OWNrN3Q4RWhvd2FoZk1VM0lWWVFCSWFhTXhDd3gK",
      "endpoints": [
        "https://github.com/powange/regie-son/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/yt-dlp"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
